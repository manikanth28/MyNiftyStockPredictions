{
  "name": "stock-recommendation-platform",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace web",
    "build:web": "npm run build --workspace web",
    "start:web": "npm run start --workspace web",
    "daily:market-scan": "node scripts/refresh-market-data.mjs",
    "daily:market-scan:loop": "node scripts/refresh-market-data.mjs --loop",
    "test:web": "npm run typecheck --workspace web",
    "test:api": "python -m unittest discover -s services/api/tests -t services/api"
  }
}
